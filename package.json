{
  "name": "copilot-pr-reviewer",
  "version": "0.1.0",
  "description": "CodeRabbit-style AI code reviewer for Azure DevOps PRs using GitHub Copilot SDK.",
  "type": "module",
  "engines": {
    "node": ">= 22.0.0"
  },
  "dependencies": {
    "@github/copilot-sdk": "~0.1.32",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.57.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/sdk-metrics": "^1.30.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/semantic-conventions": "^1.30.0",
    "minimatch": "~10.0",
    "tslib": "~2.8",
    "yaml": "~2.7",
    "zod": "~3.24"
  },
  "devDependencies": {
    "@eslint/js": "~9.39",
    "@types/node": "~22",
    "@typescript-eslint/parser": "~8.54",
    "@vitest/coverage-v8": "~4.0",
    "@vitest/eslint-plugin": "~1.6",
    "eslint": "~9.39",
    "eslint-config-prettier": "~10.1",
    "globals": "~17.1",
    "prettier": "~3.8",
    "rimraf": "~6.1",
    "ts-api-utils": "~2.4",
    "tsx": "~4.19",
    "typescript": "~5.9",
    "typescript-eslint": "~8.54",
    "vitest": "~4.0"
  },
  "scripts": {
    "start": "npx tsx src/index.ts",
    "clean": "rimraf coverage build tmp",
    "prebuild": "npm run lint",
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -w -p tsconfig.json",
    "build:release": "npm run clean && tsc -p tsconfig.release.json",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run unit --config __tests__/vitest.config.ts",
    "test:coverage": "vitest run unit --config __tests__/vitest.config.ts --coverage.enabled --coverage.all",
    "test:watch": "vitest unit",
    "prettier": "prettier \"{src,__{tests}__}/**/*.{ts,mts}\" --config .prettierrc --write",
    "prettier:check": "prettier \"{src,__{tests}__}/**/*.{ts,mts}\" --config .prettierrc --check"
  },
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "volta": {
    "node": "22.16.0"
  }
}
