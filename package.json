{
	"name": "copilot-pr-reviewer",
	"version": "1.0.0",
	"description": "AI code reviewer for Azure DevOps PRs using GitHub Copilot SDK",
	"license": "MIT",
	"type": "module",
	"module": "src/index.ts",
	"engines": {
		"bun": ">= 1.0.26"
	},
	"scripts": {
		"start": "bun run src/index.ts",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"test:coverage": "bun test --coverage",
		"typecheck": "tsc --noEmit",
		"biome:fix": "biome check --fix ."
	},
	"dependencies": {
		"@github/copilot-sdk": "^0.2.0",
		"yaml": "^2.8.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@types/bun": "latest",
		"rimraf": "^6.1.3"
	},
	"peerDependencies": {
		"typescript": "^5.0.0"
	}
}
