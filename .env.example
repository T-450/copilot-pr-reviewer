# Required - authentication
COPILOT_GITHUB_TOKEN=              # GitHub token for Copilot SDK auth
ADO_PAT=                           # Azure DevOps personal access token

# Required - Azure DevOps context
ADO_ORG=                           # Azure DevOps organization name
ADO_PROJECT=                       # Azure DevOps project name
ADO_REPO_ID=                       # Repository ID
ADO_PR_ID=                         # Pull request ID

# Optional
CONFIG_PATH=.prreviewer.yml        # Path to reviewer config (default: .prreviewer.yml)
COPILOT_MODEL=gpt-4.1              # Copilot model to use (default: gpt-4.1)
REPO_ROOT=                         # Repository root path (default: process.cwd())
